<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>{% block title %}{% endblock %}</title>
</head>
<body style="font-family: system-ui, sans-serif; background: #f4f6fa; padding: 20px;">
    <div style="max-width: 560px; margin: auto; background: white; padding: 24px; border-radius: 8px;">
        <h1 style="color: #2b6cb0; margin-top: 0;">WRA602 — City Builder</h1>
        {% block content %}{% endblock %}
        <hr style="margin-top: 24px; border: 0; border-top: 1px solid #e5e7eb;">
        <small style="color: #6b7280;">Email transactionnel — ne pas répondre. ID: {{ _messageId }}</small>
    </div>
</body>
</html>
